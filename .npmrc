# Route @shashank519915-scoped packages to GitHub Packages.
# Auth token is NOT stored here (would be committed and exposed).
# - Local dev: add to your global ~/.npmrc:
#     //npm.pkg.github.com/:_authToken=<your_PAT>
# - CI: injected automatically via secrets.GITHUB_TOKEN by actions/setup-node.
@shashank519915:registry=https://npm.pkg.github.com

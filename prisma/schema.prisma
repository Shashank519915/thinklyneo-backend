// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String         @id // Clerk userId
  workflows Workflow[]
  balance   CreditBalance?
  ledgers   CreditLedger[]
  keys      ApiKey[]
  createdAt DateTime       @default(now())
}

model Workflow {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  name          String
  description   String?
  nodes         Json
  edges         Json
  status        String        @default("idle") // idle | running | done | error
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  runs          WorkflowRun[]
  webhookUrl    String?
  webhookSecret String?
}

model WorkflowRun {
  id         String    @id @default(cuid())
  workflowId String
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId     String
  scope      String // full | partial | single
  status     String // success | failed | partial
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  durationMs Int?
  orchestratorRunId String?  // Trigger.dev orchestrator task run ID for SSE re-subscription
  inputValues       Json?    // Original input values used to start the run
  nodeRuns   NodeRun[]
  ledgers    CreditLedger[]
}

model NodeRun {
  id           String      @id @default(cuid())
  runId        String
  run          WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId       String
  nodeName     String
  status       String // success | failed | skipped | running
  startedAt    DateTime
  finishedAt   DateTime?
  durationMs   Int?
  inputs       Json?
  output       Json?
  error        String?
  triggerRunId String?

  // New Audit Fields
  providerUsed     String?     // ID of the provider that successfully executed the task
  providerAttempts Json?       // Array tracking attempts
  logs             String?     // Capture execution logs
  creditCost       Int?        // Actual microcredits consumed by this node run

  @@unique([runId, nodeId])
}

model CreditBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(100000000) // Microcredits (1,000,000 = 1.00 credit; initial $100.00 = 100,000,000)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id           String       @id @default(cuid())
  userId       String
  amount       Int          // Negative for debits/holds, positive for refunds/grants
  type         String       // initial_grant | hold | deduction | refund | topup
  description  String?
  runId        String?
  nodeRunId    String?
  balanceAfter Int
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  run          WorkflowRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  keyId     String   @unique
  maskedKey String
  createdAt DateTime @default(now())
}
